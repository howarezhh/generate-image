# Copy this file to .env, then fill in your own key.
IMAGE_API_BASE_URL=https://api.xiaoxin.best/
IMAGE_API_KEY=sk-your-key-here
HOST=0.0.0.0
PORT=8010
DATABASE_PATH=storage/app.db
STORAGE_DIR=storage
MAX_CONCURRENT_TASKS=3
IMAGE_REQUEST_TIMEOUT_SECONDS=300
IMAGE_REQUEST_MAX_ATTEMPTS=2
CHAT_PLANNER_TIMEOUT_SECONDS=180
CHAT_PLANNER_MAX_ATTEMPTS=2
ENABLE_IMAGE_STABLE_RETRY=1
IMAGE_STABLE_RETRY_QUALITY=medium
